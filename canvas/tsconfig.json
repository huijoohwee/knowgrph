{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "preserveSymlinks": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": false,
    "forceConsistentCasingInFileNames": false,
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@sandbox/*": [
        "../../sandbox/*"
      ],
      "@/components/BottomPanel/*": [
        "./src/components/BottomPanel/*"
      ],
      "@/features/graph-data-table/*": ["./src/features/graph-data-table/*"],
      "@/features/markdown/*": ["./src/features/markdown/*"],
      "@/features/panels/views/preview-panel/ui/*": ["./src/features/panels/views/preview-panel/ui/*"]
    }
  },
  "include": [
    "src",
    "api"
  ],
  "exclude": [
    "src/__tests__/demo/graphrag-aie-book-chapter-summaries-demo.tsx"
  ]
}
