{
  "@context": {
    "@vocab": "https://example.org/graph#",
    "kg": "http://example.org/kg#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "owner": "schema:domainIncludes",
    "range": "schema:rangeIncludes"
  },
  "@type": "kg:SchemaConfig",
  "metadata": {
    "agenticRagSchema": "/schema/AgenticRAG",
    "renderer:palette": {
      "nodes": {
        "idea": "#007BFF",
        "hypothesis": "#FFC107",
        "execution": "#28A745",
        "pivot": "#FD7E14",
        "alert": "#DC3545"
      },
      "edges": {
        "critical": "#DC3545",
        "neutral": "#9CA3AF"
      }
    },
    "canvas:graphLayers": {
      "defaultStyle": {
        "fill": "#007BFF",
        "fillOpacity": 0.16,
        "stroke": "#007BFF",
        "strokeWidth": 1.5,
        "dash": "4,2"
      },
      "byPropertyKey": {
        "contains": {
          "fill": "#28A745",
          "fillOpacity": 0.14,
          "stroke": "#28A745",
          "strokeWidth": 1.4,
          "dash": "6,3"
        },
        "steps": {
          "fill": "#FD7E14",
          "fillOpacity": 0.18,
          "stroke": "#FD7E14",
          "strokeWidth": 1.6,
          "dash": "2,2"
        }
      }
    }
  },
  "layers": {
    "mode": "document",
    "documentStructure": {
      "minGroupSize": 2
    }
  }
}
