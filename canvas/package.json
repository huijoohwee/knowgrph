{
  "name": "canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:grph-shared": "tsc -p ../grph-shared/tsconfig.json",
    "build:settings": "tsx src/cli/extract-settings-schema.ts",
    "predev": "npm run build:grph-shared && npm run build:settings",
    "dev": "vite",
    "prebuild": "npm run build:grph-shared && npm run build:settings && npm --prefix .. run docs:update && tsx src/cli/lint-doc.ts",
    "doc:lint": "tsx src/cli/lint-doc.ts",
    "doc:sanity": "tsx src/cli/doc-sanity-check.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "precheck": "npm run build:grph-shared",
    "check": "tsc -b --noEmit",
    "pretypecheck": "npm run build:grph-shared",
    "typecheck": "tsc -b --noEmit",
    "typecheck:agenticrag": "tsc -p tsconfig.agenticrag.json --noEmit",
    "test": "npm run test:ci",
    "pretest:ci": "npm run build:grph-shared",
    "test:ci": "node --preserve-symlinks --preserve-symlinks-main ./node_modules/tsx/dist/cli.cjs src/tests/ci.ts",
    "graphrag:workflow-cli": "tsx src/cli/graphrag-config-to-workflow.ts",
    "agenticrag:trace-codebase-index": "tsx src/cli/agenticrag-trace-codebase-index.ts"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.8",
    "@types/d3": "^7.4.3",
    "clsx": "^2.1.1",
    "cesium": "^1.133.1",
    "curagrph": "file:../../curagrph",
    "grph-shared": "file:../grph-shared",
    "d3": "^7.9.0",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.19",
    "dexie": "4.3.0",
    "elkjs": "^0.10.0",
    "rxdb": "^16.19.0",
    "rxjs": "^7.8.2",
    "ag-grid-community": "^34.0.1",
    "ag-grid-react": "^34.0.1",
    "gympgrph": "file:../../gympgrph",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.11",
    "lucide-react": "^0.562.0",
    "maplibre-gl": "^5.7.3",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "mermaid": "^11.12.2",
    "monaco-editor": "^0.53.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "react-router-dom": "^7.3.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2",
    "three": "^0.170.0",
    "zustand": "^5.0.3",
    "web-worker": "^1.5.0"
  },
  "overrides": {
    "dexie": "4.3.0",
    "rxdb": {
      "dexie": "4.3.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/dagre": "^0.7.53",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it-anchor": "^7.0.0",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
