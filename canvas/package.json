{
  "name": "@knowgrph/canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "fix:entities-sourcemaps": "node ./scripts/strip-entities-sourcemaps.mjs",
    "build:grph-shared": "npm --prefix .. run build --workspace=grph-shared",
    "build:gympgrph": "npm --prefix .. run build --workspace=gympgrph",
    "prepare:linked-packages": "npm run build:grph-shared && npm run build:gympgrph",
    "prepare:litert-assets": "node ./scripts/prepare-litert-assets.mjs",
    "build:settings": "tsx src/cli/extract-settings-schema.ts",
    "doc:generate-byteplus-chat-reference": "tsx src/cli/generate-byteplus-chat-reference.ts",
    "doc:generate-byteplus-chat-codebase-index": "tsx src/cli/generate-byteplus-modelark-chat-codebase-index.ts",
    "doc:generate-byteplus-image-reference": "tsx src/cli/generate-byteplus-image-reference.ts",
    "doc:generate-byteplus-image-codebase-index": "tsx src/cli/generate-byteplus-modelark-image-codebase-index.ts",
    "doc:generate-byteplus-video-reference": "tsx src/cli/generate-byteplus-video-reference.ts",
    "doc:generate-byteplus-video-codebase-index": "tsx src/cli/generate-byteplus-modelark-video-codebase-index.ts",
    "doc:generate-grabmaps-reference": "tsx src/cli/generate-grabmaps-reference.ts",
    "doc:generate-grabmaps-sgp-admin-areas-reference": "tsx src/cli/generate-grabmaps-sgp-admin-areas-reference.ts",
    "doc:generate-grabmaps-codebase-index": "tsx src/cli/generate-grabmaps-codebase-index.ts",
    "doc:generate-openai-reference": "tsx src/cli/generate-openai-responses-reference.ts",
    "doc:generate-flow-run-all-reference": "tsx src/cli/generate-flow-run-all-reference.ts",
    "doc:generate-workspace-export-reference": "tsx src/cli/generate-workspace-export-reference.ts",
    "predev": "npm --prefix .. run dev:source:check && npm run prepare:linked-packages && npm run prepare:litert-assets && npm run fix:entities-sourcemaps && npm run build:settings",
    "dev": "vite --configLoader runner",
    "predev:care-agent": "npm run predev",
    "dev:care-agent": "VITE_KNOWGRPH_RUN_READY_DEMO=care-agent vite --configLoader runner",
    "predev:risk-copilot": "npm run predev",
    "dev:risk-copilot": "VITE_KNOWGRPH_RUN_READY_DEMO=risk-copilot vite --configLoader runner",
    "predev:xr-physics": "npm run prepare:linked-packages && npm run prepare:litert-assets && npm run fix:entities-sourcemaps && npm run build:settings",
    "dev:xr-physics": "VITE_WORKSPACE_INITIALIZATION_DOCS_ABS_ROOT=$PWD/../../huijoohwee/docs VITE_KNOWGRPH_RUN_READY_REPO_LOCAL=1 VITE_KNOWGRPH_RUN_READY_DEMO=xr-physics vite --configLoader runner --port 5174 --strictPort",
    "predev:game-fps": "npm run prepare:linked-packages && npm run fix:entities-sourcemaps && npm run build:settings",
    "dev:game-fps": "VITE_WORKSPACE_INITIALIZATION_DOCS_ABS_ROOT=$PWD/../../huijoohwee/docs VITE_KNOWGRPH_RUN_READY_REPO_LOCAL=1 VITE_KNOWGRPH_RUN_READY_DEMO=game-fps vite --configLoader runner --port 5175 --strictPort",
    "predev:5173": "npm run predev",
    "dev:5173": "vite --configLoader runner --port 5173 --strictPort",
    "prebuild": "npm run prepare:linked-packages && npm run prepare:litert-assets && npm run build:settings && if [ \"${KG_SKIP_DOCS_UPDATE:-}\" = \"1\" ]; then echo \"[knowgrph] skipping docs:preview:update\"; else npm --prefix .. run docs:preview:update && tsx src/cli/lint-doc.ts; fi",
    "doc:lint": "tsx src/cli/lint-doc.ts",
    "doc:sanity": "tsx src/cli/doc-sanity-check.ts",
    "validate:animatic-interactions": "python3 ./scripts/validate_animatic_timeline_interactions.py",
    "validate:multi-user-collaboration:e2e": "tsx ./scripts/verify-multi-user-collaboration-e2e.ts",
    "validate:strybldr-generated-video": "node ./scripts/verify-strybldr-generated-video-e2e.mjs",
    "build": "vite build --configLoader runner",
    "lint": "eslint .",
    "preview": "vite preview --configLoader runner",
    "precheck": "npm run prepare:linked-packages",
    "check": "tsc -b --noEmit",
    "pretypecheck": "npm run prepare:linked-packages",
    "typecheck": "tsc -b --noEmit",
    "typecheck:agenticrag": "tsc -p tsconfig.agenticrag.json --noEmit",
    "test": "npm run test:ci",
    "pretest:ci": "npm run prepare:linked-packages",
    "test:ci": "npm run test:ci:unit && npm run test:ci:standalone-export",
    "test:smoke:agnes:source": "node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs src/tests/subsetAgnesSmoke.ts",
    "test:smoke:miromind:source": "node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs src/tests/subsetMiroMindSmoke.ts",
    "test:smoke:rich-media": "node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs src/tests/subsetRichMediaSmoke.ts",
    "test:smoke:rich-media:browser": "node ./scripts/run_rich_media_browser_smoke.mjs",
    "test:smoke:rich-media:timing-schema": "node --test ./scripts/__tests__/rich-media-catalog-preview-timing-schema.test.mjs",
    "validate:rich-media-catalog-preview-timing": "node ./scripts/validate_rich_media_catalog_preview_timing.mjs",
    "test:smoke:mobile-keyboard:browser": "node ./scripts/run_mobile_keyboard_browser_smoke.mjs",
    "test:smoke:game-fps:source": "node --import tsx --test src/__tests__/gameFpsMissionCore.test.ts src/__tests__/gameFpsRuntimeConcurrency.test.ts src/__tests__/gameFpsDecisionStore.test.ts src/__tests__/gameFpsPersistedSeed.test.ts src/__tests__/gameModeRuntime.test.ts src/__tests__/gameModePersistenceRuntime.test.ts src/__tests__/gameModeSpatialSourceRuntime.test.ts src/__tests__/canvasSurfaceGameDeparture.test.ts && node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs src/tests/subsetGameFpsSmoke.ts",
    "test:smoke:game-fps:browser": "node ./scripts/run_game_fps_browser_smoke.mjs",
    "test:smoke:game-mode-xr-share:unit": "python3 ./scripts/verify_game_mode_xr_share_browser_smoke_test.py",
    "test:smoke:game-mode-xr-share:browser": "npm run test:smoke:game-mode-xr-share:unit && KG_TEST_VALIDATION_FORBID_HARDCODE_IN_REPO=\"$KG_GAME_MODE_VALIDATION_SHARE_URL\" npm run test:ci:unit -- policy.boundary.forbidHardcodedRuntimeValidationInput && node ./scripts/run_game_mode_xr_share_browser_smoke.mjs",
    "test:smoke:storyboard-rich-media-drop:source": "node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs src/tests/subsetStoryboardRichMediaDropSmoke.ts",
    "test:smoke:storyboard-rich-media-drop:browser": "node ./scripts/run_storyboard_rich_media_drop_browser_smoke.mjs",
    "test:live:storyboard-media-panel-retention:browser": "node ./scripts/run_storyboard_live_route_media_panel_retention.mjs",
    "test:ci:unit": "node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs src/tests/ci.ts",
    "test:html-video:browser-native-video": "node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs src/tests/tools/smoke-html-video-browser-native-video.ts",
    "test:ci:standalone-export": "node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs ./src/cli/export-canvas-html.ts --input ./src/__tests__/fixtures/webpage-artifacts/design-canvas-sample.md --output ../../data/outputs/design-canvas-sample.ci.canvas-2d.html --mode 2d && node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs ./src/cli/export-canvas-html.ts --input ./src/__tests__/fixtures/webpage-artifacts/design-canvas-sample.md --output ../../data/outputs/design-canvas-sample.ci.canvas-3d.html --mode 3d && npm run test:ci:standalone-export:browser",
    "test:ci:standalone-export:browser": "node --preserve-symlinks --preserve-symlinks-main ../node_modules/tsx/dist/cli.cjs ./src/tests/tools/verify-html-export-artifacts.ts --canvas-2d ../../data/outputs/design-canvas-sample.ci.canvas-2d.html --canvas-3d ../../data/outputs/design-canvas-sample.ci.canvas-3d.html --output-dir ../../data/outputs",
    "graphrag:workflow-cli": "tsx src/cli/graphrag-config-to-workflow.ts",
    "agenticrag:trace-codebase-index": "tsx src/cli/agenticrag-trace-codebase-index.ts",
    "codebase:search": "tsx src/cli/codebase-search.ts",
    "pdf:convert": "tsx src/cli/convert-pdf-to-md.ts",
    "webpage:markdown": "tsx src/cli/convert-webpage-url-to-md.ts",
    "github:repo-docs": "tsx src/cli/convert-github-repo-to-md.ts"
  },
  "dependencies": {
