    "@types/d3": "^7.4.3",
    "@vladmandic/human": "^3.3.6",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.19",
    "entities": "^6.0.1",
    "fflate": "^0.8.3",
    "grph-shared": "file:../grph-shared",
    "gympgrph": "file:../gympgrph",
    "hast-util-to-html": "^9.0.5",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.11",
    "lucide-react": "^0.562.0",
    "maplibre-gl": "^5.7.3",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "mermaid": "^11.12.2",
    "monaco-editor": "^0.53.0",
    "pocketbase": "^0.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-stringify": "^11.0.0",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.0.2",
    "three": "^0.170.0",
    "unified": "^11.0.5",
    "yjs": "^13.6.31",
    "zustand": "^5.0.3"
  },
  "overrides": {
    "entities": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/dagre": "^0.7.53",
    "@types/geojson": "^7946.0.16",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it-anchor": "^7.0.0",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.4.1",
    "ajv": "8.17.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^26.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
