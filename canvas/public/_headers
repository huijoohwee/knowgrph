/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# The /knowgrph canvas is embedded by the agentic-canvas-os Vercel product
# tier (airvio.co/knowgrph framed by *.vercel.app for 100% fidelity).
# frame-ancestors replaces X-Frame-Options: DENY on the canvas paths only.
# All other paths remain non-embeddable (frame-ancestors 'self' is restrictive).
/knowgrph*
  Content-Security-Policy: frame-ancestors 'self' https://*.vercel.app https://*.joohwee.pages.dev
  X-Content-Type-Options: nosniff

/knowgrph/doc-view
  Cache-Control: no-store, no-cache, must-revalidate
  Content-Security-Policy: frame-ancestors 'self' https://*.vercel.app https://*.joohwee.pages.dev

# All other routes stay frame-denied

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/cesium/*
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
