{
  "@context": "https://huijoohwee.github.io/schema/AgenticRAG/v1/context.jsonld",
  "@graph": [
    {
      "@id": "kg:stage/import",
      "@type": "kg:Node",
      "labels": ["PipelineStage"],
      "name": "Import",
      "order": 1,
      "chunk_text": "Import UI reads a source (local/URL) → produces text/bytes payloads → stores canonical document name + optional source URL.",
      "reference": "https://github.com/huijoohwee/knowgrph/blob/main/canvas/src/features/toolbar"
    },
    {
      "@id": "kg:stage/parse",
      "@type": "kg:Node",
      "labels": ["PipelineStage"],
      "name": "Parse",
      "order": 2,
      "chunk_text": "Parser registry selects best match → executes sync/worker parse → emits GraphData + warnings. JSON-LD edge inference uses @context(@type:@id) plus metadata.jsonLdMapping.contextEdgeProperties.",
      "reference": "https://github.com/huijoohwee/knowgrph/blob/main/canvas/src/features/parsers"
    },
    {
      "@id": "kg:stage/derive",
      "@type": "kg:Node",
      "labels": ["PipelineStage"],
      "name": "Derive",
      "order": 3,
      "chunk_text": "Derivations transform canonical GraphData into display-ready subsets and overlays (layers, groups/subgraphs, traversal summaries).",
      "reference": "https://github.com/huijoohwee/knowgrph/blob/main/canvas/src/lib/graph/layerDerivation.ts"
    },
    {
      "@id": "kg:stage/layout",
      "@type": "kg:Node",
      "labels": ["PipelineStage"],
      "name": "Layout",
      "order": 4,
      "chunk_text": "Layout chooses cached positions per mode → seeds forces/heuristics → stabilizes view.",
      "reference": "https://github.com/huijoohwee/knowgrph/blob/main/canvas/src/components/GraphCanvas/layout/positioning.ts"
    },
    {
      "@id": "kg:stage/render",
      "@type": "kg:Node",
      "labels": ["PipelineStage"],
      "name": "Render",
      "order": 5,
      "chunk_text": "2D scene builds SVG layers + interaction handlers → binds simulation tick → updates DOM. 3D renderer runs separately with its own layout + camera controls. Markdown viewer/presentation/gallery uses the same documentPath for selection mapping.",
      "reference": "https://github.com/huijoohwee/knowgrph/blob/main/canvas/src/pages/Canvas.tsx"
    },

