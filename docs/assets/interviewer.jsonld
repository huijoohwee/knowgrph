    {
      "@id": "aiap:transform-clip-negatives",
      "@type": ["aiap:DataTransformation", "prov:Activity"],
      "aiap:transformationType": "clipping",
      "aiap:targetFeatures": ["NoOfImage"],
      "aiap:operation": "Clip values < 0 to 0",
      "prov:wasInformedBy": {"@id": "aiap:dq-issue-negative-values"},
      "aiap:theoreticalJustification": "Prevent model from learning invalid patterns (negative image counts impossible in production)",
      "aiap:businessRationale": "Data quality: corrupted values → model instability → production failures",
      "pplan:correspondsToStep": {"@id": "aiap:pplan-step-preprocessing"},
      "mex:hasParameter": {
        "@type": "mex:ToolParameter",
        "mex:parameterName": "lower_bound",
        "mex:parameterValue": 0
      }
    },
    {
      "@id": "aiap:transform-log-skewed",
      "@type": ["aiap:DataTransformation", "prov:Activity"],
      "aiap:transformationType": "logarithmic",
      "aiap:targetFeatureCount": 10,
      "aiap:operation": "Apply log(x + 1) to features with |skewness| > 1",
      "prov:wasInformedBy": {"@id": "aiap:dq-issue-heavy-skewness"},
      "aiap:theoreticalJustification": "Gradient descent convergence: ∇L = (1/m)X^T(σ(Xθ) - y) stable when X has bounded range",
      "aiap:empiricalEvidence": "Logistic regression converged in 120 epochs with log-transform vs 500+ without",
      "aiap:businessRationale": "Model convergence: faster training → reduced compute costs ($X savings)",
      "mex:hasParameter": {
        "@type": "mex:ToolParameter",
        "mex:parameterName": "skewness_threshold",
        "mex:parameterValue": 1.0
      }
    },
