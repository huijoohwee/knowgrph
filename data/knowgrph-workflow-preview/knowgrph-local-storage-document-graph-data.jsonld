    {
      "@id": "blk:md:knowgrph-local-storage-document:list:18:1",
      "@type": "List",
      "labels": [
        "List"
      ],
      "name": "List 1",
      "chunk_text": "Canonical graph data is persisted under `LS_KEYS.graphData`.\nThe stored payload includes `GraphData.metadata.graphDataRevision` and `GraphData.metadata.hash` so derived surfaces can detect staleness.\nWrites are intentionally debounced (batched via the history scheduler) to avoid per-keystroke LocalStorage churn while still persisting edits/imports reliably.",
      "properties": {
        "order": 1
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:56+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
