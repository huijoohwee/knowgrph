    {
      "@id": "blk:md:knowgrph-local-storage-document:list:160:1",
      "@type": "List",
      "labels": [
        "List"
      ],
      "name": "List 1",
      "chunk_text": "Knowgrph keeps Geospatial Mode keys out of `canvas/src/lib/config.ls.ts` to preserve a geospatial-free core.\nThe Geospatial Mode implementation (including its persistence design) lives in the sibling repo `gympgrph` and owns its LocalStorage keys.",
      "properties": {
        "order": 1
      },
      "metadata": {
