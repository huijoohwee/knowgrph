    {
      "@id": "blk:md:knowgrph-local-storage-document:list:167:1",
      "@type": "List",
      "labels": [
        "List"
      ],
      "name": "List 1",
      "chunk_text": "Coalesced scheduler keys are structural contracts for state-sync/indexing; production code must use these keys with revision/viewKey gating, not ad-hoc `setTimeout` chains.\n`markdown-workspace:refresh` coalesces workspace FS→Markdown Workspace refresh runs; it does not replace LS keys (it only schedules `refresh()`/`mergeWorkspaceEntriesIntoSourceFiles`).\n`source-files:persist` and `source-files:workspace` coalesce sourceFiles snapshots and workspace metadata local-storage plus persisted-cache writes while preserving equality checks and revision-based gating.\n`per-document-ui` coalesces per-document UI LS writes; document-level LS keys remain the SSOT for viewport/selection/mode state.\n`graph-table:view-state` coalesces host GraphTable/Multi-dimensional Table view-state LS writes (visibili",
      "properties": {
        "order": 1
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:56+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-local-storage-document.md",
        "documentPath": "docs/documents/knowgrph-local-storage-document.md",
        "sourceUri": "file:///Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-local-storage-document.md",
        "sourcePath": "/Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-local-storage-document.md",
        "codebasePath": "docs/documents/knowgrph-local-storage-document.md#L167-172",
        "lineStart": 167,
        "lineEnd": 172,
        "sourceSha256": "4b3a7002dc84646b62552ea46b0118d2c8998295516ecec7cd27aac3ec9c8ad8"
      }
    },
