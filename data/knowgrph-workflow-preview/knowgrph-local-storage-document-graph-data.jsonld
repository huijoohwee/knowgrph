    {
      "@id": "blk:md:knowgrph-local-storage-document:list:113:6",
      "@type": "List",
      "labels": [
        "List"
      ],
      "name": "List 6",
      "chunk_text": "`manual` (default) disables automatic GraphTableDb sync from Canvas; the Graph Table header exposes a single **Sync now** action that runs a bounded GraphData→GraphTableDb sync keyed by viewKey and revision.\n`realtime` enables automatic sync on relevant revision changes: in static mode the sync key is `graphContentRevision` (structure-only), in interactive mode the sync key is `graphDataRevision` (includes position-only changes). Sync remains deduped via `lastGraphWriteRevision` and `lastSyncedRevision` to prevent loops and background churn.",
      "properties": {
        "order": 6
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:56+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-local-storage-document.md",
        "documentPath": "docs/documents/knowgrph-local-storage-document.md",
        "sourceUri": "file:///Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-local-storage-document.md",
        "sourcePath": "/Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-local-storage-document.md",
        "codebasePath": "docs/documents/knowgrph-local-storage-document.md#L113-114",
        "lineStart": 113,
        "lineEnd": 114,
        "sourceSha256": "4b3a7002dc84646b62552ea46b0118d2c8998295516ecec7cd27aac3ec9c8ad8"
      }
    },
