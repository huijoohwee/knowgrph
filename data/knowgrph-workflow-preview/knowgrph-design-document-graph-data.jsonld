    {
      "@id": "blk:md:knowgrph-design-document:list:9:1",
      "@type": "List",
      "labels": [
        "List"
      ],
      "name": "List 1",
      "chunk_text": "Import: Markdown is ingested and normalized into a parseable form.\nParse: Markdown (including Mermaid blocks) is converted into JSON-LD.\nDerive: JSON-LD is converted into `GraphData` (nodes + edges) with stable identifiers.\nLayout: Seed layout + simulation constraints produce stable node/group positions (16:9, centered, non-overlapping).\nRender: Canvas layers render nodes/edges/groups with toggle-safe caching to prevent unnecessary re-layout.",
      "properties": {
        "order": 1
      },
      "metadata": {
        "parsedAt": "2026-04-13T23:53:31+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-design-document.md",
