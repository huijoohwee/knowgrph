      }
    },
    {
      "@id": "blk:md:knowgrph-settings-document:p:154:6",
      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 6",
      "chunk_text": "**Runtime**: `canvas/src/features/chat/geminiRunGeneration.ts` uses long-running operation pattern (create task, poll up to 36 times at 10s intervals, ~6 min max). Provider-guarded to `CHAT_PROVIDER_GEMINI`.",
      "properties": {
        "text": "**Runtime**: `canvas/src/features/chat/geminiRunGeneration.ts` uses long-running operation pattern (create task, poll up to 36 times at 10s intervals, ~6 min max). Provider-guarded to `CHAT_PROVIDER_GEMINI`.",
        "order": 6,
        "charCount": 207
