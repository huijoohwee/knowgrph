    {
      "@id": "blk:md:knowgrph-settings-document:li:119:9",
      "@type": "ListItem",
      "labels": [
        "ListItem"
      ],
      "name": "FloatingPanel Chat uses a thin `useSidePanelChatSubmit` shell that resolves requ",
      "chunk_text": "FloatingPanel Chat uses a thin `useSidePanelChatSubmit` shell that resolves request guards and optimistic state, then delegates the async lifecycle to `sidePanelChatSubmitCoordinator.ts`; standard chat responses may include one `response:` YAML metadata block when non-trivial, while `chatKnowgrph` uses the strict structured KGC contract.",
      "properties": {
        "text": "FloatingPanel Chat uses a thin `useSidePanelChatSubmit` shell that resolves request guards and optimistic state, then delegates the async lifecycle to `sidePanelChatSubmitCoordinator.ts`; standard chat responses may include one `response:` YAML metadata block when non-trivial, while `chatKnowgrph` uses the strict structured KGC contract.",
        "ordered": false,
        "index": null,
        "order": 9
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:56+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
