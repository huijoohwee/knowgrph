    {
      "@id": "blk:md:knowgrph-settings-document:p:152:5",
      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 5",
      "chunk_text": "**SSOT**: `canvas/src/features/integrations/geminiVideoGenerationSsot.ts` defines the API doc rows and widget fields; `canvas/src/features/integrations/geminiVideoGenerationDefaults.ts` reads/normalizes defaults from localStorage.",
      "properties": {
        "text": "**SSOT**: `canvas/src/features/integrations/geminiVideoGenerationSsot.ts` defines the API doc rows and widget fields; `canvas/src/features/integrations/geminiVideoGenerationDefaults.ts` reads/normalizes defaults from localStorage.",
        "order": 5,
        "charCount": 230
