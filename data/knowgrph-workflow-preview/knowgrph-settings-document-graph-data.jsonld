      "name": "Paragraph 2",
      "chunk_text": "**Layout rules**",
      "properties": {
        "text": "**Layout rules**",
        "order": 2,
        "charCount": 16
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:56+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-settings-document.md",
        "documentPath": "docs/documents/knowgrph-settings-document.md",
        "sourceUri": "file:///Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-settings-document.md",
        "sourcePath": "/Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-settings-document.md",
        "codebasePath": "docs/documents/knowgrph-settings-document.md#L229",
        "lineStart": 229,
        "lineEnd": 229,
        "sourceSha256": "b986721dd83c85ebf56bf4a3525fa38a4026b6fd3756da206b6ca1c505cf7568"
      }
    },
    {
      "@id": "blk:md:knowgrph-settings-document:list:230:3",
      "@type": "List",
      "labels": [
        "List"
      ],
      "name": "List 3",
      "chunk_text": "One setting row renders as one row: Key / Type / Value do not stack into multiple rows at narrow widths.\nValue controls are right-edge aligned within the Value column (text inputs, selects, checkboxes, pill buttons).\nHeight is consistent: value controls, preview chips, and pill actions use the same baseline height (`h-6`) to keep rows visually stable.\nComposite value controls (preview + input) must be shrink-safe: wrappers use `w-full min-w-0` and inputs use `min-w-0` so the right border stays aligned.\nClean interactions: clicking inside a value control does not toggle expand/collapse; only row click toggles.",
      "properties": {
        "order": 3
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:56+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-settings-document.md",
