      "@id": "blk:md:knowgrph-settings-document:list:146:4",
      "@type": "List",
      "labels": [
        "List"
      ],
      "name": "List 4",
      "chunk_text": "`geminiVideoModel` — Gemini Veo model identifier; defaults to `CHAT_GEMINI_VIDEO_MODEL_DEFAULT` from `chatEndpoint.ts`.\n`geminiVideoAspectRatio` — Output aspect ratio; valid values: `16:9` (default), `9:16`.\n`geminiVideoResolution` — Output resolution; valid values: `720p` (default), `1080p`, `4k`.\n`geminiVideoDurationSeconds` — Video duration in seconds; valid values: `4`, `6`, `8` (default).\n`geminiVideoPersonGeneration` — Person generation policy; valid values: `allow_all` (default), `allow_adult`, `dont_allow`.",
      "properties": {
        "order": 4
      },
