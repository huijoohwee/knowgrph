    {
      "@id": "blk:md:knowgrph-ontology-document:code:5:1",
      "@type": "CodeBlock",
      "labels": [
        "CodeBlock"
      ],
      "name": "Code 1",
      "chunk_text": "- [ ] Neutrality; abstract domain logic; forbid programme-specific identifiers\n- [ ] Modularity; isolate ontology concerns; forbid mixed semantic responsibilities\n- [ ] Configuration; externalize styling; forbid hardcoded visual behavior\n- [ ] Extensibility; support ontology bundles; forbid closed vocabularies\n- [ ] Provenance; track ontology sources; forbid orphaned type definitions\n- [ ] Consistency; apply uniform patterns; forbid arbitrary ontology-specific code",
      "properties": {
        "code": "- [ ] Neutrality; abstract domain logic; forbid programme-specific identifiers\n- [ ] Modularity; isolate ontology concerns; forbid mixed semantic responsibilities\n- [ ] Configuration; externalize styling; forbid hardcoded visual behavior\n- [ ] Extensibility; support ontology bundles; forbid closed vocabularies\n- [ ] Provenance; track ontology sources; forbid orphaned type definitions\n- [ ] Consistency; apply uniform patterns; forbid arbitrary ontology-specific code",
        "order": 1,
        "charCount": 469
      },
