    {
      "@id": "sec:md:knowgrph-ontology-document:integration-bridge-multi-ontology-graphs-canvas-renderer:30",
      "@type": "Section",
      "labels": [
        "Section"
      ],
      "name": "Integration Bridge: Multi-Ontology Graphs → Canvas Renderer",
      "chunk_text": "Integration Bridge: Multi-Ontology Graphs → Canvas Renderer",
      "properties": {
        "heading": "Integration Bridge: Multi-Ontology Graphs → Canvas Renderer",
        "level": 3,
        "anchor": "integration-bridge-multi-ontology-graphs-canvas-renderer",
        "order": 5
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:52+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-ontology-document.md",
        "documentPath": "docs/documents/knowgrph-ontology-document.md",
        "sourceUri": "file:///Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-ontology-document.md",
        "sourcePath": "/Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-ontology-document.md",
        "codebasePath": "docs/documents/knowgrph-ontology-document.md#L30",
        "lineStart": 30,
        "lineEnd": 30,
        "sourceSha256": "29937080329ce4e0ab0453c7825bf47932da97fb7448da48fe497611164d847b"
      }
    },
    {
      "@id": "blk:md:knowgrph-ontology-document:table:32:1",
      "@type": "Table",
      "labels": [
        "Table"
      ],
      "name": "Table 1",
      "chunk_text": "| Multi-Ontology Stage            | Canvas Renderer Equivalent                    | Configuration Controls                                    |\n|---------------------------------|-----------------------------------------------|-----------------------------------------------------------|\n| Ontology Context Declaration    | `@context` mapping in JSON-LD                 | `metadata.ontologies` array with `{prefix, iri}` objects  |\n| Type-Based Node Styling         | Node visual properties via schema-config      | `nodeShapes`, `nodeColors`, `nodeSizes` by `rdf:type`     |\n| Layer-Based Filtering           | Semantic/Document/Schema layer modes          | `layers.mode`, `layers.semantic.hiddenNodeTypes`          |\n| Spatial Clustering              | Graph-layer outlines over communities       ",
      "properties": {
        "markdown": "| Multi-Ontology Stage            | Canvas Renderer Equivalent                    | Configuration Controls                                    |\n|---------------------------------|-----------------------------------------------|-----------------------------------------------------------|\n| Ontology Context Declaration    | `@context` mapping in JSON-LD                 | `metadata.ontologies` array with `{prefix, iri}` objects  |\n| Type-Based Node Styling         | Node visual properties via schema-config      | `nodeShapes`, `nodeColors`, `nodeSizes` by `rdf:type`     |\n| Layer-Based Filtering           | Semantic/Document/Schema layer modes          | `layers.mode`, `layers.semantic.hiddenNodeTypes`          |\n| Spatial Clustering              | Graph-layer outlines over communities         | `geo:Geometry` nodes, `layers.semantic.communityDetection` |\n| Provenance Chains               | Edge rendering of PROV-O relationships        | `prov:wasAttributedTo`, `prov:wasGeneratedBy` styling     |",
        "order": 1
      },
      "metadata": {
