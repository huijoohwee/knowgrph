      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 3",
      "chunk_text": "**Note**: Property layer is a legacy hint for raw attributes. Renderer layer mode is controlled by `schema.layers.mode` (`document` | `schema` | `semantic`), not property layer metadata.",
      "properties": {
