      "name": "Paragraph 1",
      "chunk_text": "**Validation Standards**:",
      "properties": {
        "text": "**Validation Standards**:",
        "order": 1,
        "charCount": 25
      },
      "metadata": {
        "parsedAt": "2026-04-28T01:34:20+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
