    {
      "@id": "blk:md:knowgrph-metadata-document:table:494:2",
      "@type": "Table",
      "labels": [
        "Table"
      ],
      "name": "Table 2",
      "chunk_text": "| Context              | Intent                          | Directive                                                                                   |\n|----------------------|---------------------------------|---------------------------------------------------------------------------------------------|\n| Schema Derivation    | Read graph hints, don't override | - [ ] Copy `metadata.layers` from graph to `layersFromGraph`; forbid parser logic in schema-config generation |\n| Curator Freedom      | Allow manual overrides          | - [ ] Curators can modify `layers`, `corpusSizePresets` in schema-config; forbid automated reverts |\n| Tool Compatibility   | Enable LLM/tool updates         | - [ ] Tools read schema-config metadata as source of truth; update via JSON-LD; forbid hardcoded logic ",
      "properties": {
        "markdown": "| Context              | Intent                          | Directive                                                                                   |\n|----------------------|---------------------------------|---------------------------------------------------------------------------------------------|\n| Schema Derivation    | Read graph hints, don't override | - [ ] Copy `metadata.layers` from graph to `layersFromGraph`; forbid parser logic in schema-config generation |\n| Curator Freedom      | Allow manual overrides          | - [ ] Curators can modify `layers`, `corpusSizePresets` in schema-config; forbid automated reverts |\n| Tool Compatibility   | Enable LLM/tool updates         | - [ ] Tools read schema-config metadata as source of truth; update via JSON-LD; forbid hardcoded logic |",
        "order": 2
      },
      "metadata": {
        "parsedAt": "2026-04-28T01:34:20+00:00",
        "source": "knowgrph_parser.graph_builder",
