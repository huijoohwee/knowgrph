      "@type": "CodeBlock",
      "labels": [
        "CodeBlock"
      ],
      "name": "Code 4",
      "chunk_text": "{\n  \"corpusSizePresets\": {\n    \"small\": {\n      \"layers\": {\n        \"semantic\": {\n          \"topKEdgesPerNode\": 10,\n          \"minSimilarity\": {\n            \"cosine\": 0.2,\n            \"pmi\": 0.3\n          }\n        }\n      }\n    },\n    \"medium\": {\n      \"layers\": {\n        \"semantic\": {\n          \"topKEdgesPerNode\": 5,\n          \"minSimilarity\": {\n            \"cosine\": 0.3,\n            \"pmi\": 0.5\n          }\n        }\n      }\n    },\n    \"large\": {\n      \"layers\": {\n        \"semantic\": {\n          \"topKEdgesPerNode\": 3,\n          \"minSimilarity\": {\n            \"cosine\": 0.4,\n            \"pmi\": 0.7\n          }\n        }\n      }\n    }\n  }\n}",
      "properties": {
        "code": "{\n  \"corpusSizePresets\": {\n    \"small\": {\n      \"layers\": {\n        \"semantic\": {\n          \"topKEdgesPerNode\": 10,\n          \"minSimilarity\": {\n            \"cosine\": 0.2,\n            \"pmi\": 0.3\n          }\n        }\n      }\n    },\n    \"medium\": {\n      \"layers\": {\n        \"semantic\": {\n          \"topKEdgesPerNode\": 5,\n          \"minSimilarity\": {\n            \"cosine\": 0.3,\n            \"pmi\": 0.5\n          }\n        }\n      }\n    },\n    \"large\": {\n      \"layers\": {\n        \"semantic\": {\n          \"topKEdgesPerNode\": 3,\n          \"minSimilarity\": {\n            \"cosine\": 0.4,\n            \"pmi\": 0.7\n          }\n        }\n      }\n    }\n  }\n}",
