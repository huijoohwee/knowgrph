    {
      "@id": "blk:md:knowgrph-metadata-document:table:469:4",
      "@type": "Table",
      "labels": [
        "Table"
      ],
      "name": "Table 4",
      "chunk_text": "| Step | Action                                  | Output                                      |\n|------|-----------------------------------------|---------------------------------------------|\n| 1    | Parse markdown into JSON-LD graph       | `graph_jsonld` object in memory             |\n| 2    | Derive schema-config from graph         | `schema-config.jsonld` object in memory     |\n| 3    | Extract `metadata.layers` from schema   | Nested JSON object                          |\n| 4    | Pretty-print to stdout                  | Formatted JSON with 2-space indentation     |\n| 5    | Exit without writing files              | No filesystem artifacts                     |",
      "properties": {
        "markdown": "| Step | Action                                  | Output                                      |\n|------|-----------------------------------------|---------------------------------------------|\n| 1    | Parse markdown into JSON-LD graph       | `graph_jsonld` object in memory             |\n| 2    | Derive schema-config from graph         | `schema-config.jsonld` object in memory     |\n| 3    | Extract `metadata.layers` from schema   | Nested JSON object                          |\n| 4    | Pretty-print to stdout                  | Formatted JSON with 2-space indentation     |\n| 5    | Exit without writing files              | No filesystem artifacts                     |",
        "order": 4
      },
