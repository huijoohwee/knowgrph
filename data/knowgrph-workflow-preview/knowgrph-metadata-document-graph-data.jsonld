        "lineEnd": 560,
        "sourceSha256": "0095d2179a3a1bb1aa717c01ef86f17b338d1749f05b23d8040a84fda0ddf863"
      }
    },
    {
      "@id": "blk:md:knowgrph-metadata-document:p:562:2",
      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 2",
      "chunk_text": "**Portability Rule**: Producers preserve relative `documentPath` segments when provided (e.g., `docs/example.md`) and strip absolute filesystem paths down to the basename (e.g., `example.md`) to forbid environment-coupled provenance.",
      "properties": {
        "text": "**Portability Rule**: Producers preserve relative `documentPath` segments when provided (e.g., `docs/example.md`) and strip absolute filesystem paths down to the basename (e.g., `example.md`) to forbid environment-coupled provenance.",
        "order": 2,
        "charCount": 233
      },
      "metadata": {
        "parsedAt": "2026-04-28T01:34:20+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-metadata-document.md",
