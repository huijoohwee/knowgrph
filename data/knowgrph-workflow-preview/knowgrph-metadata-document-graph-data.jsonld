    {
      "@id": "blk:md:knowgrph-metadata-document:p:560:1",
      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 1",
      "chunk_text": "**Fallback Chain**: `documentPath` (strip `#L` fragment) → `codebaseRelPath` → `codebasePath` (if unavoidable)",
      "properties": {
        "text": "**Fallback Chain**: `documentPath` (strip `#L` fragment) → `codebaseRelPath` → `codebasePath` (if unavoidable)",
        "order": 1,
        "charCount": 110
      },
      "metadata": {
        "parsedAt": "2026-04-28T01:34:20+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-metadata-document.md",
        "documentPath": "docs/documents/knowgrph-metadata-document.md",
        "sourceUri": "file:///Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-metadata-document.md",
        "sourcePath": "/Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-metadata-document.md",
        "codebasePath": "docs/documents/knowgrph-metadata-document.md#L560",
