    {
      "@id": "blk:md:knowgrph-codebase-semantics-document:table:17:1",
      "@type": "Table",
      "labels": [
        "Table"
      ],
      "name": "Table 1",
      "chunk_text": "| Context      | Intent                         | Directive                                                                    |\n|--------------|--------------------------------|------------------------------------------------------------------------------|\n| Identifiers  | Keep IDs stable across runs     | - [ ] Normalize paths; forbid platform-specific or absolute-path identifiers |\n| Semantics    | Preserve meaning in structures  | - [ ] Encode relationships as edges; forbid implicit link semantics          |\n| Provenance   | Trace every derived artifact    | - [ ] Attach source/timestamp; forbid orphaned nodes/edges                   |\n| Integration  | Maintain clear contracts        | - [ ] Exchange JSON-LD only; forbid renderer depending on Python internals   |\n| Traversal    | Keep ",
      "properties": {
        "markdown": "| Context      | Intent                         | Directive                                                                    |\n|--------------|--------------------------------|------------------------------------------------------------------------------|\n| Identifiers  | Keep IDs stable across runs     | - [ ] Normalize paths; forbid platform-specific or absolute-path identifiers |\n| Semantics    | Preserve meaning in structures  | - [ ] Encode relationships as edges; forbid implicit link semantics          |\n| Provenance   | Trace every derived artifact    | - [ ] Attach source/timestamp; forbid orphaned nodes/edges                   |\n| Integration  | Maintain clear contracts        | - [ ] Exchange JSON-LD only; forbid renderer depending on Python internals   |\n| Traversal    | Keep traversal bounded          | - [ ] Configure depth/labels; forbid hidden traversal rules                  |",
        "order": 1
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:53+00:00",
        "source": "knowgrph_parser.graph_builder",
