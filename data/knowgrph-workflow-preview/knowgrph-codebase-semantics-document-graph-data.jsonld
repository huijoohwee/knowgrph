      "@type": "List",
      "labels": [
        "List"
      ],
      "name": "List 3",
      "chunk_text": "When a graph declares the AgenticRAG context IRI, Canvas materializes `GraphData.context` as an object with `@vocab` + minimal `@type:@id` terms (e.g., `source/target/documentUrl/reference`) so edge inference and UI diagnostics stay schema-aligned.",
      "properties": {
        "order": 3
      },
