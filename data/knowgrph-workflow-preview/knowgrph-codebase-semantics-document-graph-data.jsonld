    {
      "@id": "blk:md:knowgrph-codebase-semantics-document:table:39:1",
      "@type": "Table",
      "labels": [
        "Table"
      ],
      "name": "Table 1",
      "chunk_text": "| Context     | Intent                      | Directive |\n|------------|-----------------------------|----------|\n| Semantics  | Bound sentence pair growth  | - [ ] Cap per-sentence entity pairing by `max_syntactic_path_length`; forbid O(m²) explosions |\n| Patterns   | Bound block co-occurrences  | - [ ] Cap per-block entity set size for pattern mining; forbid O(k²) scans on large blocks |\n| Counting   | Avoid repeated full scans    | - [ ] Compute mention counts in one pass; forbid O(E·M) rescans |\n| Ignore     | Avoid repeated path checks   | - [ ] Precompile ignore matcher + cache per-path results; forbid repeated per-node pattern normalization |",
      "properties": {
        "markdown": "| Context     | Intent                      | Directive |\n|------------|-----------------------------|----------|\n| Semantics  | Bound sentence pair growth  | - [ ] Cap per-sentence entity pairing by `max_syntactic_path_length`; forbid O(m²) explosions |\n| Patterns   | Bound block co-occurrences  | - [ ] Cap per-block entity set size for pattern mining; forbid O(k²) scans on large blocks |\n| Counting   | Avoid repeated full scans    | - [ ] Compute mention counts in one pass; forbid O(E·M) rescans |\n| Ignore     | Avoid repeated path checks   | - [ ] Precompile ignore matcher + cache per-path results; forbid repeated per-node pattern normalization |",
        "order": 1
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:53+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
