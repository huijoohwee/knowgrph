    {
      "@id": "blk:md:knowgrph-ui-ux-design-document:code:5:1",
      "@type": "CodeBlock",
      "labels": [
        "CodeBlock"
      ],
      "name": "Code 1",
      "chunk_text": "- [ ] Affordances; preserve user interactions; forbid breaking UI gestures\n- [ ] Clarity; communicate state explicitly; forbid implicit behavior\n- [ ] Consistency; align UI and schema semantics; forbid divergent vocabularies\n- [ ] Mobile-first; design narrow screens first; forbid desktop-only acceptance\n- [ ] Neutrality; support any domain content; forbid domain-specific UI assumptions\n- [ ] Performance; keep interactions responsive; forbid unthrottled hot-path work\n- [ ] Stability; cleanup listeners and timers; forbid memory leaks",
      "properties": {
        "code": "- [ ] Affordances; preserve user interactions; forbid breaking UI gestures\n- [ ] Clarity; communicate state explicitly; forbid implicit behavior\n- [ ] Consistency; align UI and schema semantics; forbid divergent vocabularies\n- [ ] Mobile-first; design narrow screens first; forbid desktop-only acceptance\n- [ ] Neutrality; support any domain content; forbid domain-specific UI assumptions\n- [ ] Performance; keep interactions responsive; forbid unthrottled hot-path work\n- [ ] Stability; cleanup listeners and timers; forbid memory leaks",
        "order": 1,
        "charCount": 537
      },
