    },
    {
      "@id": "blk:md:knowgrph-ui-ux-design-document:p:140:1",
      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 1",
      "chunk_text": "**Primary directive**: Use Toast for transient UI feedback; forbid duplicate “Banner” implementations drifting from toast behavior.",
      "properties": {
        "text": "**Primary directive**: Use Toast for transient UI feedback; forbid duplicate “Banner” implementations drifting from toast behavior.",
        "order": 1,
        "charCount": 131
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:53+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-ui-ux-design-document.md",
        "documentPath": "docs/documents/knowgrph-ui-ux-design-document.md",
        "sourceUri": "file:///Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-ui-ux-design-document.md",
        "sourcePath": "/Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-ui-ux-design-document.md",
        "codebasePath": "docs/documents/knowgrph-ui-ux-design-document.md#L140",
        "lineStart": 140,
        "lineEnd": 140,
        "sourceSha256": "a3cb877b0e0618f599a0183a99abb3247e5724b921e7792caf2454c113f566cd"
      }
    },
    {
      "@id": "blk:md:knowgrph-ui-ux-design-document:table:142:2",
      "@type": "Table",
      "labels": [
        "Table"
      ],
      "name": "Table 2",
      "chunk_text": "| Context | Intent | Directive |\n|---------|--------|-----------|\n| Toast stacking | Keep notifications legible | - [ ] Newest toast anchors at default Y; older push downward; forbid overlap |\n| Toast lifetime | Avoid sticky noise | - [ ] Default auto-dismiss by TTL; allow persistent “loading” toasts only with explicit dismiss |\n| State transitions | Preserve causality | - [ ] For event transitions (loading → loaded/error), emit a new toast event and dismiss loading shortly after; forbid overwriting status so users miss the transition |\n| Cleanup | Avoid leaks | - [ ] Clear timers/listeners on unmount; forbid orphaned intervals/timeouts |",
      "properties": {
        "markdown": "| Context | Intent | Directive |\n|---------|--------|-----------|\n| Toast stacking | Keep notifications legible | - [ ] Newest toast anchors at default Y; older push downward; forbid overlap |\n| Toast lifetime | Avoid sticky noise | - [ ] Default auto-dismiss by TTL; allow persistent “loading” toasts only with explicit dismiss |\n| State transitions | Preserve causality | - [ ] For event transitions (loading → loaded/error), emit a new toast event and dismiss loading shortly after; forbid overwriting status so users miss the transition |\n| Cleanup | Avoid leaks | - [ ] Clear timers/listeners on unmount; forbid orphaned intervals/timeouts |",
        "order": 2
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:53+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-ui-ux-design-document.md",
