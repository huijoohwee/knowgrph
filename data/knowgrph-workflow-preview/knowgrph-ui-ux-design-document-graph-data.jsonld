      "properties": {
        "heading": "Interaction Contracts",
        "level": 2,
        "anchor": "interaction-contracts",
        "order": 5
      },
      "metadata": {
        "parsedAt": "2026-04-16T15:31:10+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
