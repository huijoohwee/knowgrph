    {
      "@id": "blk:md:knowgrph-ui-ux-design-document:table:18:1",
      "@type": "Table",
      "labels": [
        "Table"
      ],
      "name": "Table 1",
      "chunk_text": "| Context        | Intent                         | Directive                                                                   |\n|----------------|--------------------------------|-----------------------------------------------------------------------------|\n| Interaction    | Preserve affordance contracts  | - [ ] Keep gestures stable; forbid hidden breaking changes                  |\n| Observability  | Make state legible             | - [ ] Surface selection/filters/modes; forbid invisible mode changes        |\n| Performance    | Maintain frame budget          | - [ ] Debounce/throttle hot events; forbid per-mousemove heavy computation  |\n| Neutrality     | Avoid domain coupling          | - [ ] Drive labels and semantics via config; forbid dataset-specific UX     |\n| Accessibility  | S",
      "properties": {
        "markdown": "| Context        | Intent                         | Directive                                                                   |\n|----------------|--------------------------------|-----------------------------------------------------------------------------|\n| Interaction    | Preserve affordance contracts  | - [ ] Keep gestures stable; forbid hidden breaking changes                  |\n| Observability  | Make state legible             | - [ ] Surface selection/filters/modes; forbid invisible mode changes        |\n| Performance    | Maintain frame budget          | - [ ] Debounce/throttle hot events; forbid per-mousemove heavy computation  |\n| Neutrality     | Avoid domain coupling          | - [ ] Drive labels and semantics via config; forbid dataset-specific UX     |\n| Accessibility  | Support inclusive usage        | - [ ] Use semantic roles/labels; forbid inaccessible controls               |",
        "order": 1
      },
      "metadata": {
