    },
    {
      "@id": "blk:md:knowgrph-ui-ux-design-document:p:34:2",
      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 2",
      "chunk_text": "**Interaction Flow**: Input → Selection → Inspection → Edit → Persist → Render refresh",
      "properties": {
        "text": "**Interaction Flow**: Input → Selection → Inspection → Edit → Persist → Render refresh",
        "order": 2,
        "charCount": 86
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:53+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-ui-ux-design-document.md",
        "documentPath": "docs/documents/knowgrph-ui-ux-design-document.md",
        "sourceUri": "file:///Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-ui-ux-design-document.md",
        "sourcePath": "/Users/huijoohwee/Documents/GitHub/knowgrph/docs/documents/knowgrph-ui-ux-design-document.md",
        "codebasePath": "docs/documents/knowgrph-ui-ux-design-document.md#L34",
        "lineStart": 34,
        "lineEnd": 34,
        "sourceSha256": "a3cb877b0e0618f599a0183a99abb3247e5724b921e7792caf2454c113f566cd"
      }
    },
    {
      "@id": "blk:md:knowgrph-ui-ux-design-document:p:36:3",
      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 3",
      "chunk_text": "**Responsive Baseline**: Mobile viewport → tablet split view → desktop multi-panel canvas → wide-canvas inspection. Wider layouts may reveal more simultaneous surfaces, but the mobile path owns the primary task order.",
      "properties": {
        "text": "**Responsive Baseline**: Mobile viewport → tablet split view → desktop multi-panel canvas → wide-canvas inspection. Wider layouts may reveal more simultaneous surfaces, but the mobile path owns the primary task order.",
        "order": 3,
        "charCount": 217
      },
      "metadata": {
        "parsedAt": "2026-05-24T02:20:53+00:00",
        "source": "knowgrph_parser.graph_builder",
        "codebaseRoot": "/Users/huijoohwee/Documents/GitHub/knowgrph",
        "codebaseRelPath": "docs/documents/knowgrph-ui-ux-design-document.md",
