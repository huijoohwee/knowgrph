    {
      "@id": "blk:md:knowgrph-ui-ux-design-document:p:32:1",
      "@type": "Paragraph",
      "labels": [
        "Paragraph"
      ],
      "name": "Paragraph 1",
      "chunk_text": "**Component Stack**: Canvas Page → Canvas Renderer → Panels → Editors → Tooling",
      "properties": {
        "text": "**Component Stack**: Canvas Page → Canvas Renderer → Panels → Editors → Tooling",
        "order": 1,
        "charCount": 79
      },
      "metadata": {
