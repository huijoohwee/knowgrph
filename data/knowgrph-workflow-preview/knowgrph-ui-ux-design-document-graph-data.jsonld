        "codebasePath": "docs/documents/knowgrph-ui-ux-design-document.md#L32",
        "lineStart": 32,
        "lineEnd": 32,
        "sourceSha256": "a3cb877b0e0618f599a0183a99abb3247e5724b921e7792caf2454c113f566cd"
