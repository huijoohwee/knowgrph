{
  "name": "knowgrph",
  "private": true,
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    }
  },
  "scripts": {
    "setup": "npm --prefix canvas install",
    "hooks:install": "node ./scripts/install-git-hooks.mjs",
    "postinstall": "npm run setup && npm run hooks:install",
    "predev": "npm run setup",
    "dev": "npm --prefix canvas run dev --",
    "dev:all": "bash scripts/dev-all.sh",
    "build": "npm --prefix canvas run build",
    "pages:build": "KG_SKIP_DOCS_UPDATE=1 VITE_BASE_PATH=/knowgrph/ npm --prefix canvas run build",
    "pages:check-sync": "node ./scripts/sync-pages-knowgrph.mjs --check",
    "pages:sync": "node ./scripts/sync-pages-knowgrph.mjs",
    "pages:build-sync": "npm run pages:build && npm run pages:sync",
    "pages:functions:build": "node ./scripts/build-pages-functions-worker.mjs",
    "pages:deploy-cloudflare": "npm run pages:build-sync && npm run pages:functions:build && npx wrangler pages deploy ../huijoohwee --project-name=joohwee --branch=main --commit-dirty=true",
    "pages:build-sync-cloudflare": "npm run pages:build-sync && npm run workers:deploy",
    "agent-ready:check": "node ./scripts/check-agent-ready.mjs",
    "auth-md:check": "node ./scripts/check-auth-md.mjs",
    "dns-aid:check": "node ./scripts/check-dns-aid-cloudflare.mjs",
    "dns-aid:publish": "node ./scripts/publish-dns-aid-cloudflare.mjs",
    "agnes:readiness:check": "node ./scripts/check-agnes-readiness.mjs",
    "storage:worker:dev": "npx --yes wrangler dev --config cloudflare/workers/knowgrph-storage/wrangler.toml",
    "storage:worker:deploy": "npx --yes wrangler deploy --config cloudflare/workers/knowgrph-storage/wrangler.toml",
    "payment:worker:dev": "npx --yes wrangler dev --config cloudflare/workers/knowgrph-payment/wrangler.toml",
    "payment:worker:deploy": "npx --yes wrangler deploy --config cloudflare/workers/knowgrph-payment/wrangler.toml",
    "storage:d1:migrate:local": "npx --yes wrangler d1 migrations apply knowgrph-storage --local --config cloudflare/workers/knowgrph-storage/wrangler.toml",
    "storage:d1:migrate:remote": "npx --yes wrangler d1 migrations apply knowgrph-storage --remote --config cloudflare/workers/knowgrph-storage/wrangler.toml",
    "storage:d1:seed:docs": "node ./scripts/seed-storage-docs-to-cloudflare.mjs",
    "storage:d1:seed:docs:dry-run": "node ./scripts/seed-storage-docs-to-cloudflare.mjs --dry-run",
    "storage:deploy": "npm run storage:d1:migrate:remote && npm run storage:worker:deploy",
    "workers:deploy": "npm run storage:d1:migrate:remote && npm run storage:worker:deploy && npm run payment:worker:deploy",
    "hygiene:check": "node ./scripts/check-hygiene-compliance.mjs --changed",
    "hygiene:audit": "node ./scripts/check-hygiene-compliance.mjs --all",
    "hygiene:chunks": "node ./scripts/check-hygiene-compliance.mjs --chunks",
    "conflict:check": "npm run hygiene:check && npm run pages:build && npm run hygiene:chunks && node ./scripts/check-conflict-compliance.mjs",
    "api-index:generate": "npx tsx --tsconfig canvas/tsconfig.json canvas/src/cli/generateApiCodebaseIndex.ts",
    "api-index:check": "npx tsx --tsconfig canvas/tsconfig.json canvas/src/cli/generateApiCodebaseIndex.ts --check",
    "preview": "npm --prefix canvas run preview --",
    "lint": "npm --prefix canvas run lint",
    "check": "npm --prefix canvas run check",
    "test": "npm --prefix canvas run test:ci",
    "superagent:example": "python3 -m knowgrph_parser superagent --input knowgrph_parser/fixtures/superagent-neutral.md --output-dir data/outputs/superagent-neutral-example --run-id superagent-neutral-example",
    "superagent:pixverse:smoke": "python3 -m knowgrph_parser pixverse-smoke --print-summary",
    "pixverse:readiness:e2e": "python3 canvas/scripts/validate_pixverse_readiness_e2e.py",
    "goal:run": "python3 -m knowgrph_parser run-goal --input knowgrph_parser/fixtures/superagent-neutral.md --goal-file goal --output-dir data/outputs/goal-run-current --run-id goal-run-current --print-summary",
    "superagent:test": "python3 -m unittest knowgrph_parser.superagent_harness_test",
    "pipeline": "python3 -m knowgrph_parser pipeline",
    "graphrag:example-workflow": "python3 -m knowgrph_parser graphrag-workflow",
    "docs:byteplus-chat-reference": "npm --prefix canvas run doc:generate-byteplus-chat-reference",
    "docs:byteplus-chat-codebase-index": "npm --prefix canvas run doc:generate-byteplus-chat-codebase-index",
    "docs:byteplus-image-reference": "npm --prefix canvas run doc:generate-byteplus-image-reference",
    "docs:byteplus-image-codebase-index": "npm --prefix canvas run doc:generate-byteplus-image-codebase-index",
    "docs:byteplus-video-reference": "npm --prefix canvas run doc:generate-byteplus-video-reference",
    "docs:byteplus-video-codebase-index": "npm --prefix canvas run doc:generate-byteplus-video-codebase-index",
    "docs:openai-reference": "npm --prefix canvas run doc:generate-openai-reference",
    "docs:preview:update": "node ./scripts/update-docs.mjs --preview-only",
    "docs:update": "node ./scripts/update-docs.mjs",
    "docs:qa": "npm run docs:update && npm --prefix canvas run doc:lint && npm --prefix canvas run doc:sanity && npm run lint && npm run check && npm test",
    "docs:grabmaps-reference": "npm --prefix canvas run doc:generate-grabmaps-reference",
    "docs:grabmaps-sgp-admin-areas": "npm --prefix canvas run doc:generate-grabmaps-sgp-admin-areas-reference",
    "docs:grabmaps-codebase-index": "npm --prefix canvas run doc:generate-grabmaps-codebase-index"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
