{
  "name": "knowgrph",
  "private": true,
  "workspaces": [
    "canvas",
    "cloudflare/workers/knowgrph-mcp",
    "grph-shared",
    "gympgrph",
    "mcp"
  ],
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    },
    "esbuild": "^0.25.12"
  },
  "scripts": {
    "setup": "npm install",
    "hooks:install": "node ./scripts/install-git-hooks.mjs",
    "postinstall": "npm run hooks:install",
    "dev": "npm run dev --workspace=@knowgrph/canvas --",
    "dev:all": "bash scripts/dev-all.sh",
    "build": "npm run build --workspace=@knowgrph/canvas",
    "pages:build": "KG_SKIP_DOCS_UPDATE=1 VITE_BASE_PATH=/knowgrph/ npm run build --workspace=@knowgrph/canvas",
    "pages:check-sync": "node ./scripts/sync-pages-knowgrph.mjs --check",
    "pages:sync": "node ./scripts/sync-pages-knowgrph.mjs",
    "pages:build-sync": "npm run pages:build && npm run pages:sync",
    "pages:functions:build": "node ./scripts/build-pages-functions-worker.mjs",
    "pages:deploy-cloudflare": "npm run pages:build-sync && npm run pages:functions:build && npx wrangler pages deploy ../huijoohwee --project-name=joohwee --branch=main --commit-dirty=true && npm run storage:d1:seed:docs",
    "pages:github-write:configure": "node ./scripts/configure-pages-github-write.mjs",
    "e2e:github-canonical-storage:dev": "npm -C canvas run test:ci:unit -- sourceFiles.githubWrite",
    "e2e:github-canonical-storage:prod": "node ./scripts/e2e-github-canonical-storage-sync.mjs",
    "e2e:github-canonical-storage": "npm run e2e:github-canonical-storage:dev && npm run e2e:github-canonical-storage:prod",
    "pages:build-sync-cloudflare": "npm run pages:build-sync && npm run workers:deploy",
    "agent-ready:check": "node ./scripts/check-agent-ready.mjs",
    "vdeoxpln:check": "node ./scripts/check-vdeoxpln.mjs",
    "auth-md:check": "node ./scripts/check-auth-md.mjs",
    "dns-aid:contract": "node ./scripts/check-dns-aid-contract.mjs",
    "dns-aid:check": "node ./scripts/check-dns-aid-cloudflare.mjs",
    "dns-aid:publish": "node ./scripts/publish-dns-aid-cloudflare.mjs",
    "agnes:readiness:check": "node ./scripts/check-agnes-readiness.mjs",
    "miromind:readiness:check": "node ./scripts/check-miromind-readiness.mjs",
    "storage:worker:dev": "npx --yes wrangler dev --config cloudflare/workers/knowgrph-storage/wrangler.toml",
    "storage:worker:deploy": "npx --yes wrangler deploy --config cloudflare/workers/knowgrph-storage/wrangler.toml",
    "payment:worker:dev": "npx --yes wrangler dev --config cloudflare/workers/knowgrph-payment/wrangler.toml",
    "payment:worker:deploy": "npx --yes wrangler deploy --config cloudflare/workers/knowgrph-payment/wrangler.toml",
    "mcp:worker:dev": "npx --yes wrangler dev --config cloudflare/workers/knowgrph-mcp/wrangler.toml",
    "mcp:worker:deploy": "npx --yes wrangler deploy --config cloudflare/workers/knowgrph-mcp/wrangler.toml",
    "mcp:worker:test": "node --test cloudflare/workers/knowgrph-mcp/__tests__/*.test.mjs",
    "web:build": "npm run build --prefix web",
    "web:test": "node --test web/__tests__/*.test.mjs",
    "runtime:verify": "node ./scripts/verify-runtime-ready.mjs",
    "runtime:proof": "node ./scripts/capture-runtime-proof.mjs",
    "runtime:demo-pack": "node ./scripts/build-demo-pack-from-proof.mjs",
    "runtime:submission-brief": "node ./scripts/export-submission-brief.mjs",
    "runtime:bundle": "node ./scripts/package-submission-bundle.mjs",
    "runtime:flow": "node ./scripts/run-hosted-submission-flow.mjs",
    "runtime:test": "node --test --test-concurrency=1 cloudflare/workers/knowgrph-mcp/__tests__/*.test.mjs cloudflare/workers/knowgrph-mcp/__pbt__/*.test.mjs mcp/__tests__/*.test.mjs mcp/__pbt__/*.test.mjs web/__tests__/*.test.mjs web/__pbt__/*.test.mjs contracts/__tests__/*.test.mjs contracts/__pbt__/*.test.mjs",
    "payment:stripe:configure": "node ./scripts/configure-stripe-payment-worker.mjs",
    "payment:stripe:readiness": "node ./scripts/check-stripe-payment-readiness.mjs",
    "payment:x402:configure": "node ./scripts/configure-x402-payment-worker.mjs",
    "payment:x402:readiness": "node ./scripts/check-agent-ready-commerce.mjs",
    "payment:readiness": "node ./scripts/check-payment-readiness.mjs",
    "payment:d1:migrate:local": "npx --yes wrangler d1 migrations apply knowgrph-storage --local --config cloudflare/workers/knowgrph-payment/wrangler.toml",
    "payment:d1:migrate:remote": "npx --yes wrangler d1 migrations apply knowgrph-storage --remote --config cloudflare/workers/knowgrph-payment/wrangler.toml",
    "storage:d1:migrate:local": "npx --yes wrangler d1 migrations apply knowgrph-storage --local --config cloudflare/workers/knowgrph-storage/wrangler.toml",
    "storage:d1:migrate:remote": "npx --yes wrangler d1 migrations apply knowgrph-storage --remote --config cloudflare/workers/knowgrph-storage/wrangler.toml",
    "storage:d1:seed:docs": "node ./scripts/seed-storage-docs-to-cloudflare.mjs",
    "storage:d1:seed:docs:dry-run": "node ./scripts/seed-storage-docs-to-cloudflare.mjs --dry-run",
    "storage:deploy": "npm run storage:d1:migrate:remote && npm run storage:worker:deploy && npm run storage:d1:seed:docs",
    "workers:deploy": "npm run storage:deploy && npm run payment:worker:deploy",
    "hygiene:check": "node ./scripts/check-hygiene-compliance.mjs --changed",
    "hygiene:audit": "node ./scripts/check-hygiene-compliance.mjs --all",
    "hygiene:layout": "node ./scripts/check-hygiene-compliance.mjs --layout-only",
    "hygiene:chunks": "node ./scripts/check-hygiene-compliance.mjs --chunks",
    "conflict:check": "npm run hygiene:check && npm run pages:build && npm run hygiene:chunks && node ./scripts/check-conflict-compliance.mjs",
    "api-index:generate": "npx tsx --tsconfig canvas/tsconfig.json canvas/src/cli/generateApiCodebaseIndex.ts",
    "api-index:check": "npx tsx --tsconfig canvas/tsconfig.json canvas/src/cli/generateApiCodebaseIndex.ts --check",
    "preview": "npm run preview --workspace=@knowgrph/canvas --",
    "lint": "npm run lint --workspace=@knowgrph/canvas",
    "check": "npm run check --workspace=@knowgrph/canvas",
    "test": "npm run test:ci --workspace=@knowgrph/canvas",
    "superagent:example": "python3 -m knowgrph_parser superagent --input knowgrph_parser/fixtures/superagent-neutral.md --output-dir data/outputs/superagent-neutral-example --run-id superagent-neutral-example",
    "superagent:pixverse:smoke": "python3 -m knowgrph_parser pixverse-smoke --print-summary",
    "pixverse:readiness:e2e": "python3 canvas/scripts/validate_pixverse_readiness_e2e.py",
    "goal:run": "python3 -m knowgrph_parser run-goal --input knowgrph_parser/fixtures/superagent-neutral.md --goal-file goal --output-dir data/outputs/goal-run-current --run-id goal-run-current --print-summary",
    "superagent:test": "python3 -m unittest knowgrph_parser.superagent_harness_test",
    "pipeline": "python3 -m knowgrph_parser pipeline",
    "graphrag:example-workflow": "python3 -m knowgrph_parser graphrag-workflow",
    "docs:byteplus-chat-reference": "npm run doc:generate-byteplus-chat-reference --workspace=@knowgrph/canvas",
    "docs:byteplus-chat-codebase-index": "npm run doc:generate-byteplus-chat-codebase-index --workspace=@knowgrph/canvas",
    "docs:byteplus-image-reference": "npm run doc:generate-byteplus-image-reference --workspace=@knowgrph/canvas",
    "docs:byteplus-image-codebase-index": "npm run doc:generate-byteplus-image-codebase-index --workspace=@knowgrph/canvas",
    "docs:byteplus-video-reference": "npm run doc:generate-byteplus-video-reference --workspace=@knowgrph/canvas",
    "docs:byteplus-video-codebase-index": "npm run doc:generate-byteplus-video-codebase-index --workspace=@knowgrph/canvas",
    "docs:openai-reference": "npm run doc:generate-openai-reference --workspace=@knowgrph/canvas",
    "docs:preview:update": "node ./scripts/update-docs.mjs --preview-only",
    "docs:update": "node ./scripts/update-docs.mjs",
    "docs:qa": "npm run docs:update && npm run doc:lint --workspace=@knowgrph/canvas && npm run doc:sanity --workspace=@knowgrph/canvas && npm run lint && npm run check && npm test",
    "docs:grabmaps-reference": "npm run doc:generate-grabmaps-reference --workspace=@knowgrph/canvas",
    "docs:grabmaps-sgp-admin-areas": "npm run doc:generate-grabmaps-sgp-admin-areas-reference --workspace=@knowgrph/canvas",
    "docs:grabmaps-codebase-index": "npm run doc:generate-grabmaps-codebase-index --workspace=@knowgrph/canvas"
  },
  "dependencies": {
    "@x402/core": "^2.13.0",
    "@x402/evm": "^2.13.0",
    "@x402/hono": "^2.13.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "jsonwebtoken": "9.0.2",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "fast-check": "3.23.2"
  }
}
